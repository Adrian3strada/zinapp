# Copia a .env.web y edita con tu dominio público (no el de Railway).
# Luego: npm run build:web

# URL que compartirás con usuarios (sin /app al final si usas raíz)
WEB_PUBLIC_URL=https://zinapp.mx

# API: mismo dominio (/api) o subdominio (https://api.zinapp.mx/api)
EXPO_PUBLIC_API_URL=https://zinapp.mx/api

# "/" = https://zinapp.mx/  |  "/app" = https://tu-dominio.com/app/
EXPO_PUBLIC_WEB_BASE_PATH=/
