# Copia a .env.web y edita con tu dominio público (no el de Railway).
# Luego: npm run build:web
# .env.web está en .gitignore (no lo subas al repo).

# URL que compartirás con usuarios (sin /app al final si usas raíz)
WEB_PUBLIC_URL=https://zinapp.com.mx

# API: mismo dominio (/api) o subdominio
EXPO_PUBLIC_API_URL=https://zinapp.com.mx/api

# "/" = https://zinapp.com.mx/  |  "/app" = https://zinapp.com.mx/app/
EXPO_PUBLIC_WEB_BASE_PATH=/app

# Google Sign-In (Client ID Web). Ver docs/google-sign-in.md
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
