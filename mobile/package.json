{
  "name": "zinapp-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --go",
    "start:clear": "expo start --go --clear",
    "start:tunnel": "expo start --go --tunnel",
    "start:dev": "expo start --dev-client",
    "start:web": "powershell -ExecutionPolicy Bypass -File ./scripts/start-web.ps1",
    "android": "expo start --go --android",
    "ios": "expo start --go --ios",
    "web": "powershell -ExecutionPolicy Bypass -File ./scripts/start-web.ps1",
    "build:web": "powershell -ExecutionPolicy Bypass -File ./scripts/build-web.ps1",
    "build:web:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/build-web.ps1 -Deploy",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:all": "eas build --profile production --platform all",
    "submit:android": "eas submit --profile production --platform android",
    "submit:ios": "eas submit --profile production --platform ios",
    "publish:stores": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-stores.ps1",
    "google-play": "powershell -ExecutionPolicy Bypass -File ./scripts/google-play.ps1",
    "app-store": "powershell -ExecutionPolicy Bypass -File ./scripts/app-store.ps1"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.18.3",
    "axios": "^1.18.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "typescript": "^5.3.0"
  },
  "private": true
}
