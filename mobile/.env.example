# Variables para builds EAS (preview / production)
# Copia a .env.local o configura en expo.dev → Secrets

EXPO_PUBLIC_API_URL=https://zinapp.com.mx/api
EXPO_PUBLIC_ENV=preview

# Google Maps — opcional; sin key se usan mapas OpenStreetMap en el APK
# Configura en expo.dev → Project → Secrets → GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=
