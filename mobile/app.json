{
  "expo": {
    "name": "ZinApp",
    "slug": "zinapp",
    "owner": "g2adriaans-team",
    "version": "1.1.12",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png",
      "name": "ZinApp",
      "shortName": "ZinApp",
      "description": "Comida a domicilio y servicios locales en Zinapécuaro, Michoacán.",
      "lang": "es",
      "themeColor": "#1E5DB8",
      "backgroundColor": "#FFFFFF",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zinapp.delivery",
      "buildNumber": "3",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ZinApp usa tu ubicación para mostrar restaurantes cercanos y el seguimiento de tu pedido.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ZinApp comparte tu ubicación en segundo plano mientras realizas entregas activas.",
        "NSLocationAlwaysUsageDescription": "ZinApp comparte tu ubicación en segundo plano mientras realizas entregas activas.",
        "UIBackgroundModes": [
          "location"
        ],
        "NSPhotoLibraryUsageDescription": "ZinApp accede a tus fotos para adjuntar comprobantes de pago o imágenes del pedido.",
        "NSCameraUsageDescription": "ZinApp usa la cámara para tomar fotos de comprobantes o del pedido.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zinapp.delivery",
      "versionCode": 131,
      "edgeToEdgeEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "queries": [
        {
          "scheme": "geo"
        },
        {
          "scheme": "google.navigation"
        },
        {
          "scheme": "comgooglemaps"
        },
        {
          "scheme": "waze"
        },
        {
          "package": "com.google.android.apps.maps"
        },
        {
          "package": "com.waze"
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E4FD8"
      }
    },
    "extra": {
      "eas": {
        "projectId": "56ddb1bb-632f-4087-9a80-e839403c24fc"
      },
      "apiUrl": "https://zinapp-api-production.up.railway.app/api",
      "privacyPolicyUrl": "https://zinapp-api-production.up.railway.app/privacidad/",
      "supportEmail": "adrianestradachavez123@gmail.com",
      "deliveryFee": 25,
      "transferInfo": {
        "bank": "BBVA",
        "clabe": "012180015217582489",
        "holder": "ZinApp Delivery",
        "whatsapp": "4171803128",
        "note": "Envía el comprobante por WhatsApp con tu número de pedido."
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ZinApp usa tu ubicación para el delivery en Zinapécuaro.",
          "locationAlwaysAndWhenInUsePermission": "ZinApp comparte tu ubicación en segundo plano mientras realizas entregas activas.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1E5DB8",
          "sounds": [
            "./assets/sounds/bell.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ZinApp accede a tus fotos para adjuntar comprobantes de pago o imágenes del pedido.",
          "cameraPermission": "ZinApp usa la cámara para tomar fotos de comprobantes o del pedido."
        }
      ],
      "expo-secure-store"
    ]
  }
}
