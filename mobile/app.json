{
  "expo": {
    "name": "ZinApp",
    "slug": "zinapp",
    "owner": "g2adriaans-team",
    "version": "1.1.8",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8622C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zinapp.delivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ZinApp usa tu ubicación para mostrar restaurantes cercanos y el seguimiento de tu pedido."
      }
    },
    "android": {
      "package": "com.zinapp.delivery",
      "versionCode": 118,
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8622C"
      }
    },
    "extra": {
      "eas": {
        "projectId": "56ddb1bb-632f-4087-9a80-e839403c24fc"
      },
      "apiUrl": "https://zinapp-api-production.up.railway.app/api",
      "deliveryFee": 25,
      "shipmentSizes": [
        {
          "key": "small",
          "label": "Chico",
          "fee": 25,
          "hint": "Sobre, documentos o bolsa pequeña"
        },
        {
          "key": "medium",
          "label": "Mediano",
          "fee": 45,
          "hint": "Caja mediana o varios artículos"
        },
        {
          "key": "large",
          "label": "Grande",
          "fee": 70,
          "hint": "Caja grande o paquete pesado"
        }
      ],
      "transferInfo": {
        "bank": "BBVA",
        "clabe": "012180015217582489",
        "holder": "ZinApp Delivery",
        "whatsapp": "4171803128",
        "note": "Envía el comprobante por WhatsApp con tu número de pedido."
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ZinApp usa tu ubicación para el delivery en Zinapécuaro."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E8622C",
          "sounds": ["./assets/sounds/bell.wav"]
        }
      ],
      "expo-image-picker",
      "expo-secure-store"
    ]
  }
}
