# Producción con Docker Compose (PostgreSQL + API + Caddy opcional)
# Copia: copy .env.production.example .env
# Deploy: .\scripts\deploy-production.ps1
#         .\scripts\deploy-production.ps1 -WithHttps

# Genera SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Mínimo 32 caracteres; nunca uses valores django-insecure-* en producción.
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=api.zinapp.mx,tu-dominio.com
PORT=8000

CSRF_TRUSTED_ORIGINS=https://api.zinapp.mx,https://tu-dominio.com
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://zinapp.com.mx

# Recomendado en producción multi-worker para throttling consistente.
# Railway/Redis: usa la URL privada del plugin.
REDIS_URL=

USE_SQLITE=False

# Railway inyecta DATABASE_URL al vincular el plugin Postgres (no hace falta definirla aquí)
# DATABASE_URL=
DB_NAME=zinapp_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

# Prefer private object storage or an edge proxy for media. Enable only when
# this Django instance must serve public images itself.
SERVE_MEDIA=false
API_DOCS_ENABLED=false
SEED_DATA=false
ALLOW_DEMO_SEED=false
# Email — recuperación de contraseña (Resend SMTP)
# https://resend.com → API Keys. Sin dominio verificado usa onboarding@resend.dev
# (solo llega al email de tu cuenta Resend). En prod: verifica zinapp.com.mx.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ZinApp <onboarding@resend.dev>

# Soporte (app móvil + botón WhatsApp en landing)
SUPPORT_WHATSAPP=

# Landing (/): pega el link real de App Store / Play
APP_STORE_URL=
PLAY_STORE_URL=

# false = bloquear cuentas demo (cliente1, rest_pizzas…). Obligatorio en producción real.
DEMO_ACCOUNTS_ENABLED=false

# Cron interno (Railway cron / scripts): Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Opcional: ruta persistente si montas volumen (Railway: /app/media)
# MEDIA_ROOT=/app/media

API_DOMAIN=api.zinapp.mx

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BACK_URL=https://api.zinapp.mx/pago/ok
MERCADOPAGO_WEBHOOK_URL=https://api.zinapp.mx/api/payments/mercadopago/webhook/
# Required for signed Mercado Pago webhooks.
MERCADOPAGO_WEBHOOK_SECRET=
