# Copia a .env (local sin Docker) o usa .env.docker.example para Docker Compose
# Setup rápido Docker: .\scripts\setup-env.ps1

SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
PORT=8000

CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

USE_SQLITE=True

# PostgreSQL local (Windows suele usar puerto 5433; Docker publica 5433→5432)
# Setup: .\scripts\setup-postgres-local.ps1
DB_NAME=zinapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5433

SERVE_MEDIA=True
SEED_DATA=false

API_DOMAIN=localhost

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BACK_URL=
MERCADOPAGO_WEBHOOK_URL=

CRON_SECRET=

# Landing (/): links de tiendas y WhatsApp
APP_STORE_URL=
PLAY_STORE_URL=
SUPPORT_WHATSAPP=

# Producción real: DEMO_ACCOUNTS_ENABLED=false
DEMO_ACCOUNTS_ENABLED=True
