# Copia a .env (local sin Docker) o usa .env.docker.example para Docker Compose
# Setup rápido Docker: .\scripts\setup-env.ps1

SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
PORT=8000

CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Opcional: cache compartido para throttling/rate limits.
# REDIS_URL=redis://localhost:6379/0

USE_SQLITE=True

# PostgreSQL local (Windows suele usar puerto 5433; Docker publica 5433→5432)
# Setup: .\scripts\setup-postgres-local.ps1
DB_NAME=zinapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5433

SERVE_MEDIA=True
API_DOCS_ENABLED=True
SEED_DATA=false
# Required together with SEED_DATA for ephemeral demo environments only.
ALLOW_DEMO_SEED=false

API_DOMAIN=localhost

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BACK_URL=
MERCADOPAGO_WEBHOOK_URL=
# Obtain this secret from Mercado Pago's webhook configuration.
MERCADOPAGO_WEBHOOK_SECRET=

CRON_SECRET=

# Email — recuperación de contraseña (Resend API HTTP; evita cuelgues SMTP)
# https://resend.com → API Keys
# Sin dominio verificado: DEFAULT_FROM_EMAIL=ZinApp <onboarding@resend.dev>
#   (solo llega al email de tu cuenta Resend).
# Con dominio zinapp.com.mx verificado: ZinApp <noreply@zinapp.com.mx>
RESEND_API_KEY=
# Compat opcional (si EMAIL_HOST es resend.com, EMAIL_HOST_PASSWORD se usa como API key HTTP)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ZinApp <onboarding@resend.dev>

# Landing (/): app web, WhatsApp y contacto opcional
LANDING_APP_URL=https://zinapp.com.mx/app/
APP_STORE_URL=https://apps.apple.com/app/id6789001540
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.zinapp.delivery
SUPPORT_WHATSAPP=
SUPPORT_EMAIL=
SUPPORT_PHONE=
SOCIAL_INSTAGRAM=
SOCIAL_FACEBOOK=
TERMS_URL=

# Producción real: DEMO_ACCOUNTS_ENABLED=false
DEMO_ACCOUNTS_ENABLED=True

# Google Sign-In (OAuth Client ID tipo Web; varios separados por coma)
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_IDS=
