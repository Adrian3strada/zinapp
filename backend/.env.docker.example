# =============================================================================
# ZinApp Backend — variables para Docker Compose
#
# Copia este archivo a .env antes de levantar contenedores:
#   Windows:  copy .env.docker.example .env
#   Linux:    cp .env.docker.example .env
#   Script:   .\scripts\setup-env.ps1
#
# Desarrollo (SQLite):  docker compose up -d --build
# Producción (Postgres): docker compose -f docker-compose.prod.yml up -d --build
# Producción + HTTPS:    docker compose -f docker-compose.prod.yml --profile https up -d --build
# =============================================================================

# --- Django ---
# Genera SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*
PORT=8000

# Orígenes permitidos (producción: https://tu-dominio.com)
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006

# --- Base de datos ---
# Desarrollo rápido (sin Docker Postgres): USE_SQLITE=True
USE_SQLITE=True

# Docker / Railway / producción: USE_SQLITE=False + Postgres
# Local Docker Postgres:
#   docker compose -f docker-compose.yml -f docker-compose.postgres.yml up -d --build
#   USE_SQLITE=False
#   DB_HOST=db
#   DB_PORT=5432

# Railway: vincula Postgres en el proyecto → DATABASE_URL se inyecta solo
# DATABASE_URL=postgres://...
DB_NAME=zinapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# --- Archivos / arranque ---
SERVE_MEDIA=True
# Cargar cuentas demo (cliente1, rest_pizzas, repartidor1…) al iniciar contenedor
SEED_DATA=false

# --- Caddy HTTPS (solo --profile https en docker-compose.prod.yml) ---
API_DOMAIN=localhost

# --- Mercado Pago (opcional) ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BACK_URL=https://tu-dominio.com/pago/ok
MERCADOPAGO_WEBHOOK_URL=https://tu-dominio.com/api/payments/mercadopago/webhook/

# --- Cron (POST /api/cron/run/ con Authorization: Bearer <CRON_SECRET>) ---
# GitHub secret: RAILWAY_CRON_TOKEN = mismo valor
CRON_SECRET=
